 (assert
  ; the Bell numbers themselves, decimal, cross-checked vs OEIS A000110
  (= 1 (bell 0)) (= 1 (bell 1)) (= 2 (bell 2)) (= 5 (bell 3)) (= 15 (bell 4))
  (= 52 (bell 5)) (= 203 (bell 6)) (= 877 (bell 7)) (= 4140 (bell 8))
  (= 21147 (bell 9)) (= 115975 (bell 10)) (= 4213597 (bell 12)) (= 27644437 (bell 13))
  (= 51724158235372 (bell 20))                 ; past 32-bit, into bignums
  (= 4638590332229999353 (bell 25))
  ; base-36 rendering of known values
  (= "" (show 0)) (= "1" (show 1)) (= "f" (show 15)) (= "z" (show 35))
  (= "10" (show 36)) (= "zz" (show 1295))
  ; the full output matches the Ruby program's, line for line
  (= 291 (len out))
  (= (len expected) (len out))
  (leq out expected)))
