# Maintainer: gwem <cofinalsubnets@gmail.com>
pkgname=ll-git
pkgver=0.0.0
pkgrel=1
pkgdesc="list expression interpreter"
arch=(x86_64 i686 aarch64 armv7h)
url="https://github.com/cofinalsubnets/ll"
license=(Unlicense)
depends=('glibc')
makedepends=('git')
provides=('ll')
_gitname="${pkgname}"
source=("${_gitname}::git+https://github.com/cofinalsubnets/ll.git")
sha256sums=(SKIP)

pkgver() {
  cd ${_gitname}
  git checkout main &> /dev/null
  git describe --always | sed 's/-/_/g'
}
  
build() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make all_host
}

check() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make test
}

package() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make DESTDIR="${pkgdir}/" PREFIX="usr/" VIMPREFIX="usr/share/vim/vimfiles/" install
}
