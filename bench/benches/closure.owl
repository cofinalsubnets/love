; closure / higher-order stress (see bench/benches/closure.l). checksum = sum 3i.
(define N 100000)
(define (twice f) (lambda (x) (f (f x))))
(define (adder i) (lambda (x) (+ x i)))
(bench "closure"
  (lambda ()
    (let loop ((i 0) (s 0))
      (if (< i N) (loop (+ i 1) (+ s ((twice (adder i)) i))) s))))
