; Bell numbers in base 36 (see bench/benches/bell.l) -- a bignum-tower stress.
; pure-functional: memo tables (facts, bells) are `ff` maps threaded through the
; loop rather than mutated in place.
(define digits "0123456789abcdefghijklmnopqrstuvwxyz")
(define base 36)
(define (show n)
  (let loop ((n n) (s ""))
    (if (> n 0)
        (loop (quotient n base)
              (string-append (list->string (list (string-ref digits (modulo n base)))) s))
        s)))
(define (choose facts n k)
  (quotient (get facts n 1) (* (get facts k 1) (get facts (- n k) 1))))
(define (bell-run limit)
  (let loop ((i 0) (total 0) (bells empty) (facts (put empty 0 1)))
    (let* ((bi (if (< i 2) 1
                   (let bk ((k 0) (a 0))
                     (if (< k i) (bk (+ k 1) (+ a (* (choose facts (- i 1) k) (get bells k 0)))) a))))
           (bells2 (put bells i bi))
           (facts2 (put facts (+ i 1) (* (get facts i 1) (+ i 1))))
           (s (show bi)))
      (if (> (string-length s) limit) total
          (loop (+ i 1) (+ total (string-length s)) bells2 facts2)))))
(bench "bell" (lambda () (bell-run 280)))
