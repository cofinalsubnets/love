;;; owl lisp benchmark harness -- mirrors bench/bench.l. owl is purely
;;; functional: no load (this file is cat-ed ahead of each bench, like ll),
;;; immutable strings, and `ff` maps for memo tables. (time-ms) -> epoch ms;
;;; string-ref yields the code point directly. one line out:
;;;     <name> <lang> <reps> <ms> <checksum>
(define bench-min-ms 200)
(define bench-lang "owl")
(define (sum-list l) (let lp ((l l) (a 0)) (if (null? l) a (lp (cdr l) (+ a (car l))))))
(define (bench name work)
  (let loop ((reps 1))
    (let* ((t0 (time-ms))
           (chk (let rep ((i 0) (c #f)) (if (< i reps) (rep (+ i 1) (work)) c)))
           (ms (- (time-ms) t0)))
      (if (>= ms bench-min-ms)
          (print name " " bench-lang " " reps " " ms " " chk)
          (loop (* 2 reps))))))
