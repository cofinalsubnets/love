#!/bin/sh
# pre-commit: fail (do NOT regenerate) if CLAUDE.md is out of sync with its source of
# truth, test/CLAUDE.g. CLAUDE.md is just test/CLAUDE.g wrapped in a ```gwen fence
# (tools/gen_claudemd.g); Claude regenerates it by hand. This hook only verifies that
# the staged CLAUDE.md equals fence(staged test/CLAUDE.g), so a stale doc can't land.
#
# Activate (once per clone):  git config core.hooksPath tools/hooks   (or: make hooks)
set -e
root=$(git rev-parse --show-toplevel)
cd "$root"

# Nothing to check unless the doc or its source is part of this commit.
if git diff --cached --quiet -- CLAUDE.md test/CLAUDE.g; then
  exit 0
fi

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
{ printf '```gwen\n'; git show :test/CLAUDE.g; printf '```\n'; } > "$tmp"
if ! git show :CLAUDE.md | cmp -s - "$tmp"; then
  echo "pre-commit: CLAUDE.md is stale vs test/CLAUDE.g (or unstaged)." >&2
  echo "            regenerate it by hand and stage it, then re-commit:" >&2
  echo "              out/host/gl tools/gen_claudemd.g && git add CLAUDE.md" >&2
  exit 1
fi
exit 0
