# Maintainer: gwen <gwendolyn.whelan@gmail.com>
pkgname=love-git
pkgver=0.0.0
pkgrel=1
pkgdesc="love -- a small lisp where every value is an auto-curried function of one argument"
arch=(x86_64 i686 aarch64 armv7h)
url="https://github.com/cofinalsubnets/love"
license=(custom)
depends=('glibc')
makedepends=('git')
provides=('love')
conflicts=('love')
_gitname="${pkgname}"
source=("${_gitname}::git+https://github.com/cofinalsubnets/love.git")
sha256sums=(SKIP)

pkgver() {
  cd ${_gitname}
  git checkout main &> /dev/null
  git describe --always | sed 's/-/_/g'
}

build() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make host
}

check() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make test
}

package() {
  cd ${_gitname}
  git checkout main &> /dev/null
  make DESTDIR="${pkgdir}/" PREFIX="usr/" VIMPREFIX="usr/share/vim/vimfiles/" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
